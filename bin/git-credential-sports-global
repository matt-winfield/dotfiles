#!/bin/bash
# Git credential helper for github.com/Sports-Global
# Reads the PAT from $SPORTS_GLOBAL_GITHUB_TOKEN, set in ~/.zsh_secrets

case "$1" in
    get)
        # Consume the URL fields git sends on stdin
        while IFS= read -r line && [[ -n "$line" ]]; do
            :
        done
        echo "username=x-access-token"
        echo "password=${SPORTS_GLOBAL_GITHUB_TOKEN}"
        ;;
esac
