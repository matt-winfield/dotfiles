#!/usr/bin/env bash
# Git credential helper for github.com/Sports-Global
# Prefers $SPORTS_GLOBAL_GITHUB_TOKEN and otherwise resolves the matching
# 1Password item through github-access-token.

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "$1" in
    get)
        # Consume the URL fields git sends on stdin
        while IFS= read -r line && [[ -n "$line" ]]; do
            :
        done

        if token="$("$script_dir/github-access-token" SPORTS_GLOBAL_GITHUB_TOKEN 2>/dev/null)"; then
            echo "username=x-access-token"
            echo "password=${token}"
        fi
        ;;
esac
